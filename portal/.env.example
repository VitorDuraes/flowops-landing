# WaveOps Portal - variaveis de ambiente
# Sem nenhuma variavel, o portal roda em modo mock (dados em memoria, gateway
# simulado, integracoes apenas logadas). Preencha conforme for para producao.

# URL publica do app (usada em back_url do gateway e links)
APP_URL=http://localhost:3000

# Sessao / autenticacao
SESSION_SECRET=  # string aleatoria com 32+ caracteres
AUTH_ENFORCED=true            # false libera as areas logadas sem login (so para demo)
ADMIN_EMAIL=financeiro@waveops.com.br
ADMIN_PASSWORD=waveops-admin

# Banco de dados (Prisma / PostgreSQL). Vazio = modo mock.
DATABASE_URL=

# Gateway de pagamento: mock | mercadopago | asaas
PAYMENT_GATEWAY=mock

# Mercado Pago (cobranca via Checkout Pro + webhook assinado)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
# true forca o checkout sandbox quando o token e de conta de teste (APP_USR de test user)
MERCADOPAGO_SANDBOX=

# Asaas (cobranca recorrente nativa)
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

# E-mail (Resend) - login por codigo e avisos
RESEND_API_KEY=
EMAIL_FROM=WaveOps <nao-responder@waveops.com.br>

# Discord (alertas internos - substitui o Slack)
DISCORD_WEBHOOK_URL=

# WaveOps CRM = Twenty (sincronizacao one-way portal -> Twenty: empresa, contato,
#   pipeline/oportunidade, chamado, assinatura, fatura, followup). Substitui o Trello.
# Sem TWENTY_API_TOKEN o adapter so loga (nao sincroniza), igual aos demais.
# A API key e gerada no Twenty em Settings > APIs (workspace-scoped).
TWENTY_API_URL=http://localhost:3009
TWENTY_API_TOKEN=
# Estagio do pipeline em que a oportunidade nasce no pagamento (SELECT do Twenty).
TWENTY_OPPORTUNITY_STAGE=NEW

# Job de cobranca (protege /api/jobs/dunning)
CRON_SECRET=dev-cron-secret

# OpenTelemetry (producao). Vazio = nao exporta (roda igual em dev).
# Valores vem da pagina OTLP do Grafana Cloud. Ver docs/deploy-railway.md.
OTEL_SERVICE_NAME=waveops-portal
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=
